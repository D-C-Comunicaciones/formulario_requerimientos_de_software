# ═══════════════════════════════════════════════════════════
# VARIABLES DE ENTORNO PARA DESARROLLO LOCAL
# ═══════════════════════════════════════════════════════════
#
# INSTRUCCIONES:
# 1. Copia este archivo a .env.local
# 2. Reemplaza los valores de ejemplo con tus datos reales
# 3. .env.local está en .gitignore y NO se subirá a Git
# 4. Para producción, configura estas variables en Vercel Dashboard
#
# ═══════════════════════════════════════════════════════════

# ─────────────────────────────────────
# FRONTEND (Vite - Variables Públicas)
# Prefijo VITE_* las hace accesibles en el navegador
# ─────────────────────────────────────

# URL de tu aplicación (para desarrollo local usa localhost)
VITE_APP_URL=http://localhost:5173

# Nombre de la aplicación
VITE_APP_NAME=Formulario de Requerimientos

# Versión
VITE_APP_VERSION=1.0.0

# Entorno
VITE_NODE_ENV=development


# ─────────────────────────────────────
# BACKEND SERVERLESS (Variables Privadas)
# Estas NO tienen prefijo VITE_ y solo están disponibles
# en las funciones serverless de Vercel
# ─────────────────────────────────────

# API Key de Resend
# Obtén tu clave en: https://resend.com/api-keys
# Formato: re_xxxxxxxxxxxxxxxxxxxxx
RESEND_API_KEY=re_TuApiKeyDeResend

# Email remitente (FROM)
# DESARROLLO: Usa onboarding@resend.dev (no requiere verificación)
# PRODUCCIÓN: Usa tu dominio verificado (ej: noreply@tudominio.com)
SENDER_EMAIL=onboarding@resend.dev

# Nombre del remitente
SENDER_NAME=Formulario de Requerimientos

# Email del administrador (TO)
# Este email recibirá una copia de cada formulario enviado
ADMIN_EMAIL=admin@tuempresa.com


# ═══════════════════════════════════════════════════════════
# NOTAS IMPORTANTES
# ═══════════════════════════════════════════════════════════
#
# RESEND API KEY:
# - Plan gratuito: 100 emails/día, 3,000/mes
# - Regístrate en: https://resend.com
# - Genera tu API key en: https://resend.com/api-keys
#
# SENDER_EMAIL:
# - Para desarrollo: onboarding@resend.dev (provisto por Resend)
# - Para producción: Tu dominio verificado
# - Verifica dominios en: https://resend.com/domains
#
# VARIABLES VITE_*:
# - Son PÚBLICAS (visibles en el código del navegador)
# - NO pongas secretos aquí (API keys, contraseñas, etc.)
# - Solo para configuración del frontend
#
# VARIABLES SIN VITE_:
# - Son PRIVADAS (solo en servidor/serverless)
# - Seguras para API keys y secrets
# - No son accesibles desde el navegador
#
# DESARROLLO LOCAL:
# - Archivo: .env.local
# - NO subir a Git
# - Vercel CLI: vercel dev
#
# PRODUCCIÓN (Vercel):
# - No usar archivos .env
# - Configurar en: Vercel Dashboard → Settings → Environment Variables
# - Importante: Configurar para Production, Preview y Development
#
# ═══════════════════════════════════════════════════════════
