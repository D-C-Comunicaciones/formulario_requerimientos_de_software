# ====================================
# CONFIGURACIÓN DE SEGURIDAD
# ====================================

# Los códigos de acceso ahora se gestionan en: api/access-codes.ts
# Edita ese archivo directamente para agregar/modificar/eliminar códigos

# Clave secreta para firmar tokens JWT
# Genera una clave aleatoria y segura:
# node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=cambia-esto-por-una-clave-secreta-larga-y-aleatoria

# ====================================
# CONFIGURACIÓN DE EMAIL (Resend)
# ====================================

# API Key de Resend (obtener en https://resend.com/api-keys)
RESEND_API_KEY=re_xxxxxxxxxxxxx

# Email remitente (debe estar verificado en Resend)
SENDER_EMAIL=noreply@tudominio.com

# Nombre que aparecerá como remitente
SENDER_NAME=Formulario de Requerimientos de Software

# Email del administrador que recibirá las notificaciones
ADMIN_EMAIL=admin@tuempresa.com

# ====================================
# CONFIGURACIÓN DE DESARROLLO (opcional)
# ====================================

# URL de la aplicación en desarrollo
# VITE_APP_URL=http://localhost:5173

# Endpoint del API
# VITE_API_ENDPOINT=/api/send-email

