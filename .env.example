# ====================================
# CONFIGURACIÓN DE SEGURIDAD
# ====================================

# Los códigos de acceso ahora se gestionan en: api/access-codes.ts
# Edita ese archivo directamente para agregar/modificar/eliminar códigos

# Clave secreta para firmar tokens JWT
# Genera una clave aleatoria y segura:
# node -e "console.log(require('crypto').randomBytes(64).toString('hex'))"
JWT_SECRET=cambia-esto-por-una-clave-secreta-larga-y-aleatoria

# ====================================
# CONFIGURACIÓN DE EMAIL (Resend)
# ====================================

# API Key de Resend (obtener en https://resend.com/api-keys)
RESEND_API_KEY=re_xxxxxxxxxxxxx

# Email remitente (debe estar verificado en Resend)
SENDER_EMAIL=noreply@tudominio.com

# Nombre que aparecerá como remitente
SENDER_NAME=Formulario de Requerimientos de Software

# Email del administrador que recibirá las notificaciones
ADMIN_EMAIL=admin@tuempresa.com

# ====================================
# CONFIGURACIÓN DE LA APLICACIÓN
# ====================================

# URL de tu aplicación (para CORS y validación de origen)
# En Vercel, esto se puede configurar como tu dominio personalizado
# Si no se configura, se usará automáticamente VERCEL_URL
APP_URL=https://tu-dominio-personalizado.com

# ====================================
# CONFIGURACIÓN DEL FRONTEND (Variables VITE_*)
# ====================================

# URL de la aplicación (accesible desde el frontend)
# Debe coincidir con APP_URL en producción
VITE_APP_URL=https://tu-dominio-personalizado.com

# Nombre de la aplicación
VITE_APP_NAME=Formulario de Requerimientos de Software

# Versión de la aplicación
VITE_APP_VERSION=1.0.0

# Endpoint del API (ruta relativa)
VITE_API_ENDPOINT=/api/send-email

# ====================================
# NOTAS IMPORTANTES
# ====================================
# - Variables VITE_* son públicas (accesibles desde el navegador)
# - Variables sin VITE_* son privadas (solo en serverless functions)
# - VERCEL_URL es proporcionado automáticamente por Vercel
# - En desarrollo local usa: vercel dev
